{
    "scopeName": "source.vellum",
    "name": "Vellum",
    "patterns": [
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#comments"
        },
        {
            "include": "#identifiers"
        }
    ],
    "repository": {
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.vellum",
                    "match": "\\b(import|script|state|fun|var|return|if|in|else|while|for|get|set|true|false|as|event|none)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.vellum",
                    "match": "\\b(Int|Float|Bool|String|None)\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.vellum",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.vellum",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.vellum",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.vellum",
                    "begin": "//",
                    "end": "$"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "variable.other.vellum",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    }
}